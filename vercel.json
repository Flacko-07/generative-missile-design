{
  "version": 2,
  "builds": [
    { "src": "api/design.py", "use": "@vercel/python" },
    { "src": "package.json", "use": "@vercel/next" }
  ],
  "routes": [
    { "src": "/api/design", "dest": "/api/design.py" },
    { "src": "/(.*)", "dest": "/" }
  ],
  "functions": {
    "api/design.py": {
      "excludeFiles": "{node_modules/**,.next/**,public/**,brahmos.stl,hypersonic.stl,tomahawk.stl,gan_dataset/**,active_learning.py,export.py,export_weights.py,generate_final_design.py,geometry.py,merge_syn_clean.py,parametric_sweep.py,synthetic_dataset.py}"
    }
  }
}
